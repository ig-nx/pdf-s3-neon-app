# Repo-wide ignore rules for this fullstack project.

# ------------------------------
# OS / File manager
# ------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ------------------------------
# Editors / IDEs
# ------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ------------------------------
# Secrets / env files
# ------------------------------
.env
.env.*
*.env
!.env.example
!.env.sample
!.env.template

# Keys / certs
*.pem
*.key
*.crt

# ------------------------------
# Logs
# ------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------
# Python
# ------------------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage/
htmlcov/
.tox/
.nox/

# Builds / packaging
build/
dist/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Local data (optional)
*.sqlite3
*.db

# ------------------------------
# Node / Next.js
# ------------------------------
node_modules/
.next/
out/
build/
dist/
coverage/
.turbo/
.vercel/
.eslintcache
*.tsbuildinfo

